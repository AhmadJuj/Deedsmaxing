{
  "expo": {
    "name": "DeedsMaxing",
    "slug": "deedsmaxing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/chad2.png",
    "scheme": "deedsmaxing",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/chad1.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1F14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.deedsmaxing"
    },
    "android": {
      "package": "com.deedsmaxing",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "adaptiveIcon": {
        "backgroundColor": "#0A1F14",
        "foregroundImage": "./assets/images/chad2.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
